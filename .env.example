# =============================================================================
# DocuPilot AI — environment variable template
# =============================================================================
# Copy this file to `.env` (which is gitignored) before running the stack:
#
#   copy .env.example .env      # Windows (PowerShell / cmd)
#   cp   .env.example .env      # macOS / Linux
#
# docker compose reads `.env` automatically. Every value below has a built-in
# default in docker-compose.yml (via the ${VAR:-default} syntax) EXCEPT
# SA_PASSWORD, which is required — SQL Server refuses to start without a
# strong SA password.
# =============================================================================

# ---- SQL Server SA password (REQUIRED) --------------------------------------
# Must satisfy SQL Server's complexity policy: >= 8 chars and at least three
# of {uppercase, lowercase, digit, symbol}. Change this for any non-local use.
SA_PASSWORD=YourStrong!Passw0rd

# ---- Published host ports (override if one is already in use locally) -------
API_PORT=5010
WEB_PORT=4210
SQL_PORT=1433
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
OLLAMA_PORT=11434

# ---- Phase 2 — Document persistence & file storage (DA-019) -----------------
# The API/Worker read these from compose; they are not host-tunable ports so
# they live in docker-compose.yml directly, but documented here for clarity:
#   ConnectionStrings__DocuPilotDb -> Server=sqlserver,1433;Database=DocuPilot;
#       User Id=sa;Password=${SA_PASSWORD};TrustServerCertificate=True
#       (in-network SQL host = service name `sqlserver`, container port 1433 —
#        NOT the host SQL_PORT remap, which only affects host->container access)
#   FileStorage__RootPath  -> /app/files   (the docupilot-files named volume)
#   FileStorage__MaxBytes  -> 26214400     (25 MB per-file upload cap)
# SQL_PORT stays 1433 here (canonical). On a host where 1433 is reserved by
# Windows winnat, set SQL_PORT in your real .env to a free port (e.g. 14330);
# this does NOT change the in-network connection string above.

# ---- Phase 3 — Worker poll loop + extraction pipeline tuning (DA-024/DA-028) -
# These knobs tune the Phase-3 document pipeline. All have compose defaults
# (${VAR:-default}) so they're optional in .env — override only to re-tune.
#   Worker__*      are read by the Worker only (poll loop + stale-claim sweep).
#   Extraction__*  are read by the Worker (does extraction) AND surfaced by the
#                  API (validation / limits per DA-024); wired to both services.
# How long a single extraction attempt may run before timing out (per doc).
EXTRACTION_TIMEOUT_SECONDS=60
# Max extraction attempts before a doc is marked Failed (transient faults only).
EXTRACTION_MAX_ATTEMPTS=3
# Hard cap on extracted text length (chars); longer text is rejected/truncated.
EXTRACTION_MAX_TEXT_CHARS=5000000
# Worker poll interval: seconds between sweeps for the oldest Queued document.
WORKER_POLL_INTERVAL_SECONDS=5
# Stale-claim reset: a doc stuck in ExtractingText this many minutes is requeued.
WORKER_STUCK_RESET_MINUTES=15

# ---- Phase 4 — LLM classification & metadata (Ollama) (DA-032/DA-036) -------
# The Worker calls the local Ollama LLM to classify each TextExtracted doc and
# extract metadata; the API surfaces classification config. These map to the
# backend `Llm:*` options (env form `Llm__*`) and are wired to BOTH api+worker
# in docker-compose.yml. All have compose defaults (${VAR:-default}) so they're
# optional in .env — override only to re-tune or to swap model/provider.
#
# MODEL AUTO-PULL: a one-shot `ollama-model-init` service pulls LLM_MODEL into
# the `ollama-models` named volume after Ollama is healthy, then exits 0;
# api/worker wait for it (service_completed_successfully) so they never call a
# model-less Ollama. The model persists across `up`/`down` and is re-pulled
# only after `down -v`. First pull of llama3.2:3b is ~2 GB — ensure the drive
# backing Docker's data disk has headroom (Windows+WSL2: usually C:).
# MANUAL fallback if init is skipped:  docker compose exec ollama ollama pull llama3.2:3b
# CHEAP GATE (faster, lower quality):  LLM_MODEL=llama3.2:1b   (~1.3 GB)
# LATENCY: CPU-only inference is slow — expect seconds-to-tens-of-seconds per
# document. A slow first classification is normal, NOT a hang.
#
# In-network base URL: ollama service name + container port 11434 (NOT the host
# OLLAMA_PORT remap, which only affects host->container access).
LLM_BASE_URL=http://ollama:11434
# Model name (single config value — swapping is zero-code). QA cheap-gate: llama3.2:1b.
LLM_MODEL=llama3.2:3b
# API style: `ollama-native` (Ollama /api/generate) or `openai` (vLLM-compatible swap).
LLM_API_STYLE=ollama-native
# Per-call timeout (s). CPU LLM is slow; HttpClient timeout = this + ~30s buffer.
LLM_TIMEOUT_SECONDS=120
# Max attempts for transient/unparseable LLM faults before the doc is Failed.
LLM_MAX_ATTEMPTS=2
# Document text head-truncation budget (chars) fed to the model.
LLM_MAX_INPUT_CHARS=12000
# Sampling temperature: 0 = greedy/reproducible (best for a deterministic demo).
LLM_TEMPERATURE=0

# ---- Phase 5 — Chunking, Embeddings & Qdrant (DA-039/DA-043) -----------------
# Phase 5 chunks each classified document, embeds the chunks with a SECOND
# Ollama model, and upserts the vectors into Qdrant for semantic search. The
# Worker runs this pass; the API surfaces chunk counts. These map to the backend
# `Chunking:*` / `Embedding:*` / `Qdrant:*` options (env form `*__*`) and are
# wired to BOTH api+worker in docker-compose.yml. All have compose defaults
# (${VAR:-default}) so they're optional in .env — override only to re-tune or to
# swap the embedding model.
#
# SECOND MODEL AUTO-PULL: the SAME one-shot `ollama-model-init` service now pulls
# BOTH the chat model (LLM_MODEL) AND the embedding model (EMBEDDING_MODEL,
# default nomic-embed-text ~274 MB) into the `ollama-models` volume after Ollama
# is healthy, then exits 0; api/worker wait for it so NEITHER model is ever
# absent on a clean bring-up. The embedder is small (~274 MB) vs the chat model
# (~2 GB). MANUAL fallback:  docker compose exec ollama ollama pull nomic-embed-text
#
# COLLECTION BOOTSTRAP: the `document_chunks` collection is created by the APP on
# startup (at EMBEDDING_DIMENSIONS), NOT by compose. Nothing here creates it.
#
# DIM-MATCH RULE (silent-break trap): EMBEDDING_DIMENSIONS MUST equal the
# embedding model's TRUE output dimension. nomic-embed-text = 768. If you swap
# EMBEDDING_MODEL (e.g. all-minilm = 384, mxbai-embed-large = 1024) you MUST set
# EMBEDDING_DIMENSIONS to the new model's dim AND start on a FRESH Qdrant volume
# (`docker compose down -v`) so the collection re-bootstraps at the new size —
# the app's dim-validate REFUSES to use a collection whose size mismatches.
#
# Chunking: deterministic char splitter (token estimate ~= chars/4).
CHUNKING_MAX_CHARS=4000
CHUNKING_OVERLAP_CHARS=600
CHUNKING_MAX_CHUNKS_PER_DOCUMENT=1000
# Embedding: in-network Ollama base URL (service name + container port 11434).
EMBEDDING_BASE_URL=http://ollama:11434
# Embedding model — auto-pulled by ollama-model-init. Swap => see DIM-MATCH RULE.
EMBEDDING_MODEL=nomic-embed-text
# Vector dimension — MUST match EMBEDDING_MODEL's true dim (nomic-embed-text=768).
EMBEDDING_DIMENSIONS=768
# API style: `ollama-native` (Ollama /api/embeddings) or `openai` (/v1/embeddings).
EMBEDDING_API_STYLE=ollama-native
# Per-embed-call timeout (s). CPU embedding is faster than chat but still real.
EMBEDDING_TIMEOUT_SECONDS=60
# Max attempts for transient embed faults before the doc stays Classified (retry).
EMBEDDING_MAX_ATTEMPTS=3
# Qdrant: in-network host = service name `qdrant`; the app uses the gRPC channel.
QDRANT_HOST=qdrant
# Container-internal gRPC port Qdrant listens on (NOT the host QDRANT_GRPC_PORT
# publish remap above — that only affects host->container access).
QDRANT_GRPC_PORT_INTERNAL=6334
# Collection name (app-bootstrapped on startup at EMBEDDING_DIMENSIONS).
QDRANT_COLLECTION_NAME=document_chunks
# TLS to Qdrant: false for the in-network plaintext gRPC channel.
QDRANT_USE_TLS=false

# ---- Phase 6 — Semantic Search (DA-045/DA-048) -------------------------------
# Phase 6 adds a read-only semantic-search endpoint: POST /api/search embeds the
# NL query with the SAME embedding model as Phase 5, runs a cosine search over
# the Qdrant `document_chunks` vectors, collapses chunk hits to one row per
# document (best chunk wins), ranks by score, and hydrates fileName/
# classification/matchedText from SQL. These map to the backend `Search:*`
# options (env form `Search__*`).
#
# API-ONLY: search runs on docupilot-api, so these are wired ONLY to the API in
# docker-compose.yml — NOT to docupilot-worker (the Worker does not search).
#
# ALL code-defaulted (the backend already has these defaults baked in), so
# search works with ZERO env changes. The lines below are OPTIONAL overrides
# using the same ${VAR:-default} pattern — uncomment/set only to re-tune.
# Phase 6 adds NO new image, model, port, or Qdrant/SQL change (read-only over
# the existing Phase-5 vectors).
#
# Documents returned when the request omits `limit`.
SEARCH_DEFAULT_LIMIT=10
# Hard server-side clamp on the request `limit` (request is clamped to [1, this]).
SEARCH_MAX_LIMIT=50
# Over-fetch factor: fetch (limit x this) chunk hits so same-document collapse
# still yields >= limit distinct documents.
SEARCH_CHUNK_OVER_FETCH_FACTOR=5
# Absolute cap on chunk hits fetched (bounds the Qdrant limit + SQL IN-set size).
SEARCH_MAX_CHUNK_FETCH=200
# matchedText display trim (chars) for the winning chunk's content.
SEARCH_MATCHED_TEXT_MAX_CHARS=300
# Optional cosine score floor; results below are dropped only when > 0 (0 = off).
SEARCH_MIN_SCORE=0

# ---- Phase 7 — RAG Question Answering (DA-049/DA-052) ------------------------
# Phase 7 adds a document-grounded question-answering endpoint: POST /api/ask
# embeds the NL question with the SAME embedding model as Phase 5, runs a cosine
# search over the Qdrant `document_chunks` vectors for the top-k CHUNK hits,
# assembles a labeled context block, and asks the SAME Phase-4 chat LLM
# (llama3.2:3b) to answer ONLY from that context — returning the grounded answer
# plus ranked source citations. These map to the backend `Rag:*` options (env
# form `Rag__*`).
#
# API-ONLY: the ask endpoint runs on docupilot-api, so these are wired ONLY to
# the API in docker-compose.yml — NOT to docupilot-worker (the Worker does NOT
# do RAG; it keeps its Phase-5 pass-3 pipeline wiring untouched).
#
# ALL code-defaulted (the backend already bakes in these defaults), so /api/ask
# works with ZERO env changes. The lines below are OPTIONAL overrides using the
# same ${VAR:-default} pattern — set only to re-tune. Phase 7 adds NO new image,
# model, port, or Qdrant/SQL change (it reuses the Phase-4 chat LLM, the Phase-5
# embedder, and the Phase-5/6 Qdrant vectors).
#
# GROUNDING + NOT-FOUND are built into the backend (not configurable): the LLM is
# instructed to answer only from the provided context, and if it can't, /api/ask
# returns 200 with answerFound=false + a canned "I could not find enough
# information..." answer and empty citations.
#
# Chunks retrieved as context when the request omits `topK`.
RAG_TOP_K=6
# Hard server-side clamp on the request `topK` (request is clamped to [1, this]).
RAG_MAX_TOP_K=12
# Total char budget for the assembled context block fed to the LLM.
RAG_CONTEXT_MAX_CHARS=6000
# Per-chunk char cap applied before context assembly.
RAG_PER_CHUNK_MAX_CHARS=2000
# Citation `snippet` display trim (chars).
RAG_SNIPPET_MAX_CHARS=300
# Pre-LLM grounding floor: if EVERY hit's cosine score < this, the ask
# short-circuits to the canned not-found answer WITHOUT calling the LLM.
RAG_MIN_SCORE=0.25
