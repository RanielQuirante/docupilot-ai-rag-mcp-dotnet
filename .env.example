# =============================================================================
# DocuPilot AI — environment variable template
# =============================================================================
# Copy this file to `.env` (which is gitignored) before running the stack:
#
#   copy .env.example .env      # Windows (PowerShell / cmd)
#   cp   .env.example .env      # macOS / Linux
#
# docker compose reads `.env` automatically. Every value below has a built-in
# default in docker-compose.yml (via the ${VAR:-default} syntax) EXCEPT
# SA_PASSWORD, which is required — SQL Server refuses to start without a
# strong SA password.
# =============================================================================

# ---- SQL Server SA password (REQUIRED) --------------------------------------
# Must satisfy SQL Server's complexity policy: >= 8 chars and at least three
# of {uppercase, lowercase, digit, symbol}. Change this for any non-local use.
SA_PASSWORD=YourStrong!Passw0rd

# ---- Published host ports (override if one is already in use locally) -------
API_PORT=5010
WEB_PORT=4210
SQL_PORT=1433
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
OLLAMA_PORT=11434

# ---- Phase 2 — Document persistence & file storage (DA-019) -----------------
# The API/Worker read these from compose; they are not host-tunable ports so
# they live in docker-compose.yml directly, but documented here for clarity:
#   ConnectionStrings__DocuPilotDb -> Server=sqlserver,1433;Database=DocuPilot;
#       User Id=sa;Password=${SA_PASSWORD};TrustServerCertificate=True
#       (in-network SQL host = service name `sqlserver`, container port 1433 —
#        NOT the host SQL_PORT remap, which only affects host->container access)
#   FileStorage__RootPath  -> /app/files   (the docupilot-files named volume)
#   FileStorage__MaxBytes  -> 26214400     (25 MB per-file upload cap)
# SQL_PORT stays 1433 here (canonical). On a host where 1433 is reserved by
# Windows winnat, set SQL_PORT in your real .env to a free port (e.g. 14330);
# this does NOT change the in-network connection string above.

# ---- Phase 3 — Worker poll loop + extraction pipeline tuning (DA-024/DA-028) -
# These knobs tune the Phase-3 document pipeline. All have compose defaults
# (${VAR:-default}) so they're optional in .env — override only to re-tune.
#   Worker__*      are read by the Worker only (poll loop + stale-claim sweep).
#   Extraction__*  are read by the Worker (does extraction) AND surfaced by the
#                  API (validation / limits per DA-024); wired to both services.
# How long a single extraction attempt may run before timing out (per doc).
EXTRACTION_TIMEOUT_SECONDS=60
# Max extraction attempts before a doc is marked Failed (transient faults only).
EXTRACTION_MAX_ATTEMPTS=3
# Hard cap on extracted text length (chars); longer text is rejected/truncated.
EXTRACTION_MAX_TEXT_CHARS=5000000
# Worker poll interval: seconds between sweeps for the oldest Queued document.
WORKER_POLL_INTERVAL_SECONDS=5
# Stale-claim reset: a doc stuck in ExtractingText this many minutes is requeued.
WORKER_STUCK_RESET_MINUTES=15
